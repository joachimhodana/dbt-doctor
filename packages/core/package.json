{
  "name": "@dbt-doctor/core",
  "version": "0.1.2",
  "private": true,
  "description": "Internal: diagnostic engine for dbt-doctor (lint runner, scoring, config, suppressions).",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && NODE_ENV=production vp pack",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dbt-doctor/project-info": "workspace:*",
    "@dbt-doctor/types": "workspace:*",
    "dbt-doctor-rules": "workspace:*",
    "picomatch": "^4.0.4",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
