{
  "version": 1,
  "updatedAt": "2026-05-23",
  "policy": {
    "minimumCoveragePercent": 100,
    "requiredStatuses": ["covered-native", "covered-native-with-config"]
  },
  "rules": [
    {
      "sqlfluffRule": "LT01",
      "description": "Unnecessary trailing whitespace",
      "dbtDoctorRule": "sql-trailing-whitespace",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT02",
      "description": "Incorrect indentation",
      "dbtDoctorRule": "sql-indentation-consistency",
      "status": "covered-native-with-config"
    },
    {
      "sqlfluffRule": "LT03",
      "description": "Operators should follow style guide",
      "dbtDoctorRule": "sql-operator-spacing",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT04",
      "description": "Comma style",
      "dbtDoctorRule": "sql-leading-commas, sql-trailing-commas, sql-select-trailing-comma",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT05",
      "description": "Long lines",
      "dbtDoctorRule": "model-line-length",
      "status": "covered-native-with-config"
    },
    {
      "sqlfluffRule": "LT06",
      "description": "Function spacing",
      "dbtDoctorRule": "sql-function-spacing",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT07",
      "description": "CTE bracket positioning",
      "dbtDoctorRule": "sql-cte-bracket-position",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT08",
      "description": "Blank line after CTE",
      "dbtDoctorRule": "sql-cte-blank-line-after",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT09",
      "description": "Select targets on new lines",
      "dbtDoctorRule": "sql-select-targets-layout",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT10",
      "description": "Consistent keyword case",
      "dbtDoctorRule": "sql-keywords-case",
      "status": "covered-native-with-config"
    },
    {
      "sqlfluffRule": "LT11",
      "description": "Set operators surrounded by newlines",
      "dbtDoctorRule": "sql-set-operator-newline",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT12",
      "description": "File ends with trailing newline",
      "dbtDoctorRule": "sql-file-trailing-newline",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "LT13",
      "description": "Files should not begin with whitespace",
      "dbtDoctorRule": "sql-no-leading-whitespace",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "CP01",
      "description": "Keyword capitalization",
      "dbtDoctorRule": "sql-keywords-case",
      "status": "covered-native-with-config"
    },
    {
      "sqlfluffRule": "CP02",
      "description": "Identifier capitalization",
      "dbtDoctorRule": "sql-unquoted-identifiers-case",
      "status": "covered-native-with-config"
    },
    {
      "sqlfluffRule": "CP03",
      "description": "Function capitalization",
      "dbtDoctorRule": "sql-function-name-case",
      "status": "covered-native-with-config"
    },
    {
      "sqlfluffRule": "CP04",
      "description": "Boolean/null capitalization",
      "dbtDoctorRule": "sql-boolean-null-case",
      "status": "covered-native-with-config"
    },
    {
      "sqlfluffRule": "RF02",
      "description": "References should be qualified",
      "dbtDoctorRule": "sql-references-qualified",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "RF03",
      "description": "Consistent references",
      "dbtDoctorRule": "sql-reference-consistency",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "AL01",
      "description": "Tables should have explicit aliases",
      "dbtDoctorRule": "sql-explicit-table-alias",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "AL02",
      "description": "Columns should have explicit aliases",
      "dbtDoctorRule": "sql-explicit-column-alias",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "AM01",
      "description": "Ambiguous DISTINCT with GROUP BY",
      "dbtDoctorRule": "sql-ambiguous-distinct-group-by",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "AM02",
      "description": "Ambiguous UNION",
      "dbtDoctorRule": "sql-union-explicit-qualifier",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "AM03",
      "description": "Order by direction consistency",
      "dbtDoctorRule": "sql-order-by-direction-consistency",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "ST01",
      "description": "Do not use SELECT *",
      "dbtDoctorRule": "no-select-star",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "ST02",
      "description": "Simple CASE preferred where possible",
      "dbtDoctorRule": "sql-simple-case-preferred",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "ST03",
      "description": "Unused CTEs",
      "dbtDoctorRule": "sql-unused-cte",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "ST04",
      "description": "Nested CASE depth",
      "dbtDoctorRule": "sql-case-nesting",
      "status": "covered-native"
    },
    {
      "sqlfluffRule": "CV03",
      "description": "Trailing commas in SELECT",
      "dbtDoctorRule": "sql-select-trailing-comma",
      "status": "covered-native-with-config"
    }
  ]
}
